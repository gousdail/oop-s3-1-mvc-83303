@model IEnumerable<oop_s3_1_mvc_83303.Models.Course>
@{ ViewData["Title"] = "Courses"; }
<h1>Courses</h1>
<table class="table">
    <thead><tr><th>Name</th><th>Branch</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach (var item in Model) {
        <tr><td>@item.Name</td><td>@item.Branch?.Name</td>
            <td>
                <a asp-controller="Gradebook" asp-action="Index" asp-route-courseId="@item.Id" class="btn btn-info btn-sm">Gradebook</a>
                @if (User.IsInRole("Faculty") || User.IsInRole("Admin")) {
                    <a asp-controller="AttendanceRecords" asp-action="TakeAttendance" asp-route-courseId="@item.Id" class="btn btn-secondary btn-sm">Attendance</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
