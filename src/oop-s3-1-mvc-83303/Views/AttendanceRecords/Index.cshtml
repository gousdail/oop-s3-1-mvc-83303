@model IEnumerable<oop_s3_1_mvc_83303.Models.AttendanceRecord>

@{
    ViewData["Title"] = "Attendance Records";
}

<h1>Attendance Records</h1>

<table class="table">
    <thead>
        <tr>
            <th>Date</th>
            <th>Week</th>
            <th>Course</th>
            <th>Student</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@item.Date.ToShortDateString()</td>
            <td>@item.WeekNumber</td>
            <td>@item.Enrolment?.Course?.Name</td>
            <td>@item.Enrolment?.Student?.Name</td>
            <td>
                @if (item.IsPresent) {
                    <span class="badge bg-success">Present</span>
                } else {
                    <span class="badge bg-danger">Absent</span>
                }
            </td>
        </tr>
}
    </tbody>
</table>
